# Solana RPC (mainnet or devnet)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Jito block engine URL
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.io
JITO_TIP_ACCOUNT=96gYZGDn1bYYXKxWREiNtYfJfK3Dg9gXFDZmTVJBBj4N

# Yellowstone gRPC (Triton or custom)
YELLOWSTONE_GRPC_URL=https://your-yellowstone-endpoint.com:443
YELLOWSTONE_GRPC_TOKEN=your-token

# Wallet keypair (base58 private key)
WALLET_PRIVATE_KEY=

# AI provider: openai | openrouter
AI_PROVIDER=openrouter

# OpenAI API key (used when AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# OpenRouter API key (used when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# AI model (default: gpt-4o-mini for both providers)
AI_MODEL=gpt-4o-mini

# Mode: real | simulation
MODE=simulation
